# Backend environment variables
MONGODB_URI=mongodb://localhost/wilboor
JWT_SECRET=your_jwt_secret_here
ADMIN_PASSWORD=your_admin_password_here

# Use production token for real Mercado Pago transactions
MERCADO_PAGO_MODE=production
MERCADO_PAGO_ACCESS_TOKEN=APP_USR-...

# For local sandbox testing, use one of these options:
# Option 1: explicitly set sandbox mode and test token
# MERCADO_PAGO_MODE=sandbox
# MERCADO_PAGO_SANDBOX_ACCESS_TOKEN=TEST-...

# Option 2: use a TEST token directly in MERCADO_PAGO_ACCESS_TOKEN
# MERCADO_PAGO_MODE=sandbox
# MERCADO_PAGO_ACCESS_TOKEN=TEST-...

SMTP_HOST=mail.wilboor.com.br
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=contato@wilboor.com.br
SMTP_PASS=your_smtp_password_here
MAIL_FROM="wilboor.com.br <contato@wilboor.com.br>"
FRONTEND_URL=http://localhost:3000
MAIL_BCC_CONFIRMATIONS=contato@wilboor.com.br
MELHOR_ENVIO_TOKEN=your_melhor_envio_api_token_here
MELHOR_ENVIO_BASE_URL=https://api.melhorenvio.com.br
